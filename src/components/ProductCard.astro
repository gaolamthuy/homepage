---
import type { Product, ProductCardProps } from '../types/product';
import { formatVnd, getProductImage } from '../lib/utils';

export interface Props extends ProductCardProps {
  showPromotionBadge?: boolean;
  showOrderTemplate?: boolean;
}

const { product, showPromotionBadge = true, showOrderTemplate = true } = Astro.props;

function hasPromotion(product: Product): boolean {
  return product.glt_retail_promotion || false;
}
---

{product.glt_slug ? (
  <a 
    href={`/products/${product.glt_slug}`}
    class="card w-full bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 group border border-base-300 cursor-pointer block no-underline"
    data-product-category={product.category_name}
    aria-label={`Xem chi tiết ${product.full_name}`}
  >
    <figure class="relative overflow-hidden aspect-[3/4]">
      <img 
        src={getProductImage(product, true)} 
        alt={product.name}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
      <div class="absolute top-2 left-2 flex gap-1">
        {showPromotionBadge && hasPromotion(product) && (
          <div class="badge badge-primary badge-soft badge-sm">Khuyến mãi</div>
        )}
        {product.child_product && product.child_product.length > 0 && null}
      </div>
    </figure>

    <div class="card-body p-3 md:p-4 bg-base-100/95 backdrop-blur-sm">
      <h2 class="card-title text-base md:text-lg font-bold text-base-content line-clamp-2 flex items-center gap-2">
        <span>{product.full_name}</span>
      </h2>
      <p>
        {showOrderTemplate && product.order_template && (
          <div class="text-xs text-base-content/50 italic mt-1">
            {product.order_template}
          </div>
        )}
      </p>
      <div class="flex items-center justify-between mt-2">
        <div class="flex items-center gap-2">
          <span class="text-xl md:text-2xl font-bold text-primary bg-primary/10 px-2 py-1 rounded-lg">
            {formatVnd(product.base_price)}
          </span>
        </div>
      </div>
    </div>
  </a>
) : (
  <div class="card w-full bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 group border border-base-300" data-product-category={product.category_name}>
    <figure class="relative overflow-hidden aspect-[3/4]">
      <img 
        src={getProductImage(product, true)} 
        alt={product.name}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
      <div class="absolute top-2 left-2 flex gap-1">
        {showPromotionBadge && hasPromotion(product) && (
          <div class="badge badge-primary badge-soft badge-sm">Khuyến mãi</div>
        )}
        {product.child_product && product.child_product.length > 0 && null}
      </div>
    </figure>

    <div class="card-body p-3 md:p-4 bg-base-100/95 backdrop-blur-sm">
      <h2 class="card-title text-base md:text-lg font-bold text-base-content line-clamp-2 flex items-center gap-2">
        <span>{product.full_name}</span>
      </h2>
      <p>
        {showOrderTemplate && product.order_template && (
          <div class="text-xs text-base-content/50 italic mt-1">
            {product.order_template}
          </div>
        )}
      </p>
      <div class="flex items-center justify-between mt-2">
        <div class="flex items-center gap-2">
          <span class="text-xl md:text-2xl font-bold text-primary bg-primary/10 px-2 py-1 rounded-lg">
            {formatVnd(product.base_price)}
          </span>
        </div>
      </div>
    </div>
  </div>
)}
