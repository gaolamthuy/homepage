---
import { getAlbum } from '../lib/api';

let albumData: Awaited<ReturnType<typeof getAlbum>> = [];
try {
  albumData = await getAlbum();
} catch (error) {
  console.error('Error fetching album data:', error);
}

const clientAlbumData = albumData.map((item) => ({
  title: item.title_public || item.title,
  imageUrl: item.public_url || '',
}));
---

<div id="photoswipe-gallery" class="hidden"></div>

<script define:vars={{ serverAlbumData: clientAlbumData }} is:inline>
  window.__ALBUM_DATA__ = serverAlbumData || [];
</script>

<script>
  import PhotoSwipe from 'photoswipe';
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  interface AlbumEntry {
    title: string;
    imageUrl: string;
  }

  interface GalleryItem {
    src: string;
    width: number;
    height: number;
    alt: string;
    title: string;
  }

  declare global {
    interface Window {
      __ALBUM_DATA__?: AlbumEntry[];
    }
  }

  const albumData: AlbumEntry[] = window.__ALBUM_DATA__ || [];
  let lightbox: PhotoSwipeLightbox | null = null;

  function initPhotoSwipe() {
    if (lightbox) return;

    try {
      lightbox = new PhotoSwipeLightbox({
        gallery: '#photoswipe-gallery',
        children: 'a',
        showHideOpacity: true,
        bgOpacity: 0.8,
        pswpModule: PhotoSwipe
      });

      lightbox.on('uiRegister', function() {
        if (lightbox?.pswp && lightbox.pswp.ui) {
          lightbox.pswp.ui.registerElement({
            name: 'custom-caption',
            onInit: (_el: HTMLElement, _pswp: PhotoSwipe) => {
              _el.innerHTML = '<div class="pswp__caption"><div class="pswp__caption__center"></div></div>';
            }
          });
        }
      });
    } catch (error) {
      console.error('Error initializing PhotoSwipe:', error);
    }
  }

  function loadImageSize(url: string): Promise<{ width: number; height: number }> {
    return new Promise((resolve) => {
      const img = new Image();
      img.onload = () => {
        resolve({ width: img.naturalWidth, height: img.naturalHeight });
      };
      img.onerror = () => {
        resolve({ width: 1200, height: 1600 });
      };
      img.src = url;
    });
  }

  async function openGallery() {
    if (!lightbox) {
      initPhotoSwipe();
      if (!lightbox) {
        alert('PhotoSwipe chưa sẵn sàng. Vui lòng thử lại sau.');
        return;
      }
    }

    if (albumData.length === 0) {
      alert('Không có dữ liệu album.');
      return;
    }

    const galleryItemsPromises: Promise<GalleryItem | null>[] = albumData.map(async (item: AlbumEntry) => {
      if (!item.imageUrl) return null;
      const { width, height } = await loadImageSize(item.imageUrl);
      return {
        src: item.imageUrl,
        width,
        height,
        alt: item.title || 'Bảng giá',
        title: item.title || 'Bảng giá'
      };
    });

    const galleryItems = (await Promise.all(galleryItemsPromises)).filter((item): item is GalleryItem => item !== null);

    if (galleryItems.length === 0) {
      alert('Không có ảnh nào để hiển thị.');
      return;
    }

    const galleryHTML = galleryItems.map((item: GalleryItem) =>
      `<a href="${item.src}" data-pswp-width="${item.width}" data-pswp-height="${item.height}" data-pswp-srcset="${item.src} ${item.width}w" target="_blank">
        <img src="${item.src}" alt="${item.alt}" style="display: none;" />
      </a>`
    ).join('');

    const galleryContainer = document.getElementById('photoswipe-gallery');
    if (galleryContainer && lightbox) {
      galleryContainer.innerHTML = galleryHTML;
      galleryContainer.classList.remove('hidden');
      lightbox.loadAndOpen(0, galleryItems);
    }
  }

  function init() {
    initPhotoSwipe();
    const galleryButton = document.querySelector('[data-gallery-trigger]');
    if (galleryButton) {
      galleryButton.addEventListener('click', function(e: Event) {
        e.preventDefault();
        openGallery();
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
