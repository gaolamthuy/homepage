---
/**
 * TRANG BẢNG GIÁ SẢN PHẨM - PRICING TABLE
 * 
 * TÍNH NĂNG CHÍNH:
 * - Hiển thị danh sách sản phẩm với 3 chế độ giá: Giá niêm yết, Pricebook 1, Pricebook 2
 * - Lọc theo danh mục sản phẩm
 * - Luôn hiển thị child_unit (đơn vị phụ), chỉ thay đổi nội dung giá
 * - In bảng giá
 * 
 * CẤU TRÚC DỮ LIỆU:
 * - Main unit: Đơn vị chính (kg) với base_price và pricebooks
 * - Child unit: Đơn vị phụ (bao 50kg) với base_price và conversion_value
 * - Pricebook: utdao (bán lẻ), whole (bán sỉ)
 * 
 * LOGIC HIỂN THỊ (ĐÃ ĐƠN GIẢN HÓA):
 * - Giá niêm yết: Hiển thị base_price + giá trị "Quy đổi / kg" thực tế
 * - Pricebook: Hiển thị pricebook cho main unit, "-" cho child unit + placeholder "—" cho "Quy đổi / kg"
 * - Fixed width columns để tránh layout shift
 * - Sử dụng display_name từ pricebooks data cho dropdown options
 */

import Layout from '../layouts/Layout.astro';
import { getProducts, getCategories } from '../lib/api';
import type { Product } from '../types/product';

// === DATA FETCHING ===
const productData = await getProducts();
const products: Product[] = productData.products_data || [];

// === CATEGORY PROCESSING ===
// Lấy danh mục từ API và sắp xếp theo rank
const categoriesRes = await getCategories();
const rankedNames = (categoriesRes.categories_data || [])
  .slice()
  .sort((a, b) => (a.rank ?? 9999) - (b.rank ?? 9999)) // Sắp xếp theo rank, null/undefined = 9999
  .map((c) => c.category_name)
  .filter(Boolean) as string[];

// Lấy danh mục từ products (backup nếu API categories thiếu)
const fromProducts = [...new Set(products.map((p) => p.category_name))];
// Merge và dedupe: ưu tiên rankedNames, bổ sung fromProducts
const categories = [...new Set([...rankedNames, ...fromProducts])];

// === UTILITY FUNCTIONS ===

/**
 * Format số thành tiền tệ VN
 */
function formatPrice(price: number): string {
  return new Intl.NumberFormat('vi-VN').format(price);
}

---

<Layout
  title="Bảng giá - Gạo Lâm Thúy"
  description="Xem bảng giá chi tiết các sản phẩm gạo chất lượng cao từ Gạo Lâm Thúy"
>
  <div class="container mx-auto px-4 py-8 max-w-7xl">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-base-content mb-2">Bảng giá sản phẩm</h1>
      <p class="text-base-content/70">
        Cập nhật mới nhất: {new Date().toLocaleDateString('vi-VN')}
      </p>
    </div>

    <!-- Thông tin khuyến mãi -->
    <div class="mb-6 no-print">
      <div class="collapse collapse-arrow bg-gradient-to-r from-primary/10 to-secondary/10 border border-primary/20">
        <input type="checkbox" />
        <div class="collapse-title text-lg font-semibold text-primary flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
          </svg>
          🎉 Thông tin khuyến mãi đang áp dụng
        </div>
        <div class="collapse-content">
          <div class="pt-2">
            <div class="bg-base-100 rounded-lg p-4 border border-base-300">
              <h3 class="font-semibold text-base-content mb-3 flex items-center gap-2">
                <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Giảm giá theo số lượng bao
              </h3>
              <p class="text-sm text-base-content/70 mb-4">
                Áp dụng cho đơn vị <span class="badge badge-outline badge-sm">bao 50kg</span> và <span class="badge badge-outline badge-sm">bao 60kg</span>
              </p>
              
              <div class="space-y-2">
                <div class="flex items-center justify-between py-2 border-b border-base-300/50">
                  <span class="font-medium">📦 2 bao</span>
                  <span class="text-success font-semibold">Giảm 50,000 VNĐ</span>
                </div>
                <div class="flex items-center justify-between py-2 border-b border-base-300/50">
                  <span class="font-medium">📦 3 bao</span>
                  <span class="text-warning font-semibold">Giảm 120,000 VNĐ</span>
                </div>
                <div class="flex items-center justify-between py-2">
                  <span class="font-medium">📦 4+ bao</span>
                  <span class="text-primary font-semibold flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                    Liên hệ
                  </span>
                </div>
              </div>

              <div class="mt-4 p-3 bg-info/10 border border-info/20 rounded-lg">
                <p class="text-sm text-info flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>
                    <strong>Lưu ý:</strong> Khuyến mãi áp dụng trên tổng đơn hàng. Có thể kết hợp nhiều loại sản phẩm khác nhau.
                  </span>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters trong collapse -->
    <div class="mb-6 no-print">
      <div class="collapse collapse-arrow bg-base-200/50 border border-base-300">
        <input type="checkbox" />
        <div class="collapse-title text-base font-medium flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.707A1 1 0 013 7V4z" />
          </svg>
          🔍 Lọc và tùy chọn hiển thị
        </div>
        <div class="collapse-content">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:max-w-2xl pt-2">
            <label class="form-control w-full">
              <span class="label py-1"><span class="label-text font-medium">Danh mục</span></span>
              <select
                id="pricing-filter-category"
                class="select select-bordered w-full"
                aria-label="Lọc theo danh mục"
              >
                <option value="" selected>Tất cả ({products.length})</option>
                {categories.map((category) => {
                  const count = products.filter((p) => p.category_name === category).length;
                  return (
                    <option value={category}>
                      {category} ({count})
                    </option>
                  );
                })}
              </select>
            </label>

            <label class="form-control w-full">
              <span class="label py-1"><span class="label-text font-medium">Bảng giá</span></span>
              <select
                id="pricing-filter-pricebook"
                class="select select-bordered w-full"
                aria-label="Chọn pricebook hiển thị"
              >
                <option value="base_price" selected>Giá niêm yết</option>
                <option value="utdao">Bảng giá 500kg</option>
                <option value="whole">Bảng giá 200kg</option>
              </select>
            </label>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile tip -->
    <div class="block md:hidden mb-4 no-print">
      <div class="alert alert-info">
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="text-sm">
          💡 <strong>Mẹo:</strong> Vuốt sang trái/phải để xem đầy đủ bảng giá
        </span>
      </div>
    </div>

    <div class="overflow-x-auto rounded-lg border border-base-300 bg-base-100">
      <table class="table table-zebra w-full min-w-[600px]">
        <thead>
          <tr class="bg-base-200">
            <th class="text-left w-60">Tên sản phẩm</th>
            <th class="text-left w-15">Danh mục</th>
            <th class="text-left w-24">Đơn vị</th>
            <th class="text-right w-32" id="pricing-pricebook-header">Giá niêm yết</th>
            <th class="text-right w-28">Quy đổi / kg</th>
          </tr>
        </thead>
        <tbody>
          {products.map((product) => {
            const hasChild = product.child_unit;
            return (
              <>
                {/* 
                  MAIN UNIT ROW
                  - Hiển thị thông tin chính của sản phẩm
                  - Sử dụng rowspan khi có child_unit (chế độ "Giá niêm yết")
                  - js-rowspan-cell: để điều khiển rowspan động
                  - js-pricebook-cell: để cập nhật giá theo pricebook
                */}
                <tr class="hover" data-category={product.category_name}>
                  {hasChild ? (
                    <>
                      {/* Tên sản phẩm - rowspan=2 khi có child_unit */}
                      <td class="font-medium" rowspan="2">
                        <div class="break-words">
                          {/* Tên sản phẩm (có link nếu có glt_slug) */}
                          {product.glt_slug ? (
                            <a
                              href={`/products/${product.glt_slug}`}
                              class="link link-primary link-hover break-words"
                            >
                              {product.name}
                            </a>
                          ) : (
                            <span class="break-words">{product.name}</span>
                          )}
                          {/* Sub-text: order_template (thông tin vụ mùa, chất lượng) */}
                          {product.order_template && (
                            <div class="text-xs text-base-content/60 mt-1 break-words">
                              {product.order_template}
                            </div>
                          )}
                        </div>
                      </td>
                      {/* Danh mục - rowspan=2 khi có child_unit */}
                      <td rowspan="2">
                        <span class="badge badge-ghost badge-sm whitespace-nowrap">
                          {product.category_name}
                        </span>
                      </td>
                    </>
                  ) : (
                    <>
                      {/* Tên sản phẩm - không rowspan khi không có child_unit */}
                      <td class="font-medium">
                        <div class="break-words">
                          {product.glt_slug ? (
                            <a
                              href={`/products/${product.glt_slug}`}
                              class="link link-primary link-hover break-words"
                            >
                              {product.name}
                            </a>
                          ) : (
                            <span class="break-words">{product.name}</span>
                          )}
                          {product.order_template && (
                            <div class="text-xs text-base-content/60 mt-1 break-words">
                              {product.order_template}
                            </div>
                          )}
                        </div>
                      </td>
                      {/* Danh mục - không rowspan */}
                      <td>
                        <span class="badge badge-ghost badge-sm whitespace-nowrap">
                          {product.category_name}
                        </span>
                      </td>
                    </>
                  )}
                  
                  {/* Đơn vị main unit */}
                  <td class="whitespace-nowrap w-24">{product.unit}</td>
                  
                  {/* 
                    GIÁ MAIN UNIT - Cột động
                    - Mặc định: hiển thị base_price
                    - JavaScript sẽ thay đổi theo pricebook được chọn
                    - data-*: chứa tất cả giá trị để JavaScript xử lý
                  */}
                  <td
                    class="text-right font-semibold text-primary tabular-nums js-pricebook-cell w-32"
                    data-base-price={product.base_price}
                    data-utdao={product.pricebooks?.utdao?.price ?? ''}
                    data-whole={product.pricebooks?.whole?.price ?? ''}
                    data-type="base"
                  >
                    {formatPrice(product.base_price)}
                  </td>
                  
                  {/* Quy đổi/kg - chỉ có ý nghĩa với child_unit - placeholder khi chọn pricebook */}
                  <td class="text-right tabular-nums text-base-content/50 js-conversion-cell w-28">—</td>
                </tr>

                {/* 
                  CHILD UNIT ROW (nếu có)
                  - Luôn hiển thị, không ẩn/hiện
                  - Chỉ thay đổi nội dung giá: base_price hoặc "-"
                */}
                {hasChild && (
                  <tr class="hover" data-category={product.category_name}>
                    {/* Đơn vị child_unit */}
                    <td class="whitespace-nowrap w-24">{product.child_unit.unit}</td>
                    
                    {/* 
                      GIÁ CHILD UNIT
                      - base_price: hiển thị child_unit.base_price
                      - pricebook: hiển thị "-" (không tính giá)
                    */}
                    <td
                      class="text-right font-semibold text-primary tabular-nums js-pricebook-cell w-32"
                      data-base-price={product.child_unit.base_price}
                      data-utdao={product.pricebooks?.utdao?.price ?? ''}
                      data-whole={product.pricebooks?.whole?.price ?? ''}
                      data-conversion={product.child_unit.conversion_value || 50}
                      data-type="child"
                    >
                      {formatPrice(product.child_unit.base_price)}
                    </td>
                    
                    {/* Quy đổi/kg - price_per_master_unit - placeholder khi chọn pricebook */}
                    <td class="text-right tabular-nums text-base-content/90 js-conversion-cell w-28">
                      {product.child_unit.price_per_master_unit != null
                        ? formatPrice(product.child_unit.price_per_master_unit)
                        : '—'}
                    </td>
                  </tr>
                )}
              </>
            );
          })}
        </tbody>
      </table>
    </div>

    <div class="mt-6 flex justify-end no-print">
      <button type="button" class="btn btn-primary" onclick="window.print()">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 mr-2 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"
          />
        </svg>
        In bảng giá
      </button>
    </div>
  </div>
</Layout>

<script>
  /**
   * CLIENT-SIDE LOGIC - PRICING TABLE
   * 
   * CHỨC NĂNG:
   * 1. Thay đổi pricebook (Giá niêm yết / Pricebook 1 / Pricebook 2)
   * 2. Lọc theo danh mục
   * 3. Ẩn/hiện child_unit rows dựa trên pricebook
   * 4. Cập nhật rowspan động
   */

  // === CONSTANTS ===
  const NF = new Intl.NumberFormat('vi-VN');

  // === UTILITY FUNCTIONS ===
  
  /**
   * Format giá trị thành tiền tệ, xử lý edge cases
   */
  function formatCell(val: string): string {
    if (val === '' || val === 'null') return '—';
    const n = Number(val);
    if (Number.isNaN(n)) return '—';
    return NF.format(n);
  }

  // === MAIN FUNCTIONS ===

  /**
   * APPLY PRICEBOOK - Hàm chính xử lý thay đổi pricebook
   * 
   * LOGIC MỚI (đơn giản hóa):
   * - base_price: Hiển thị base_price + giá trị "Quy đổi / kg" thực tế
   * - utdao/whole: Hiển thị pricebook cho main unit, "-" cho child unit + placeholder "—" cho "Quy đổi / kg"
   * 
   * @param key - Loại pricebook được chọn
   */
  function applyPricebook(key: 'base_price' | 'utdao' | 'whole') {
    // 1. Cập nhật header cột giá
    const header = document.getElementById('pricing-pricebook-header');
    if (header) {
      if (key === 'base_price') {
        header.textContent = 'Giá niêm yết';
      } else if (key === 'utdao') {
        header.textContent = 'Bảng giá 500kg';
      } else {
        header.textContent = 'Bảng giá 200kg';
      }
    }

    // 2. Cập nhật cột "Quy đổi / kg" - hiển thị giá trị hoặc placeholder
    const showConversionValues = key === 'base_price';
    document.querySelectorAll<HTMLElement>('.js-conversion-cell').forEach((cell) => {
      // Bỏ qua header
      if (cell.tagName === 'TH') return;
      
      if (showConversionValues) {
        // Khôi phục giá trị gốc từ data attribute hoặc text content ban đầu
        const originalValue = cell.dataset.originalValue;
        if (originalValue) {
          cell.textContent = originalValue;
        }
      } else {
        // Lưu giá trị gốc và hiển thị placeholder
        if (!cell.dataset.originalValue) {
          cell.dataset.originalValue = cell.textContent || '—';
        }
        cell.textContent = '—';
      }
    });

    // 3. Cập nhật giá trong các cell
    document.querySelectorAll<HTMLElement>('.js-pricebook-cell').forEach((cell) => {
      const type = cell.dataset.type || 'base'; // 'base' hoặc 'child'

      if (key === 'base_price') {
        // CHẾ ĐỘ GIÁ NIÊM YẾT: Hiển thị base_price cho tất cả
        const basePrice = cell.dataset.basePrice;
        cell.textContent = formatCell(basePrice ?? '');
      } else {
        // CHẾ ĐỘ PRICEBOOK
        const raw = key === 'utdao' ? cell.dataset.utdao : cell.dataset.whole;

        if (type === 'base') {
          // Main unit: hiển thị trực tiếp pricebook
          cell.textContent = formatCell(raw ?? '');
        } else if (type === 'child') {
          // Child unit: hiển thị "-" (không tính giá từ pricebook)
          cell.textContent = '—';
        }
      }
    });
  }

  /**
   * APPLY CATEGORY FILTER - Lọc sản phẩm theo danh mục
   * 
   * @param value - Tên danh mục (rỗng = hiển thị tất cả)
   */
  function applyCategoryFilter(value: string) {
    document.querySelectorAll<HTMLTableRowElement>('tbody tr').forEach((row) => {
      const cat = row.dataset.category ?? '';
      if (!value || cat === value) {
        row.style.display = ''; // Hiển thị
      } else {
        row.style.display = 'none'; // Ẩn
      }
    });
  }

  // === INITIALIZATION ===

  /**
   * INIT - Khởi tạo event listeners và trạng thái ban đầu
   */
  function init() {
    // Lấy references đến các select elements
    const catSel = document.getElementById(
      'pricing-filter-category'
    ) as HTMLSelectElement | null;
    const pbSel = document.getElementById(
      'pricing-filter-pricebook'
    ) as HTMLSelectElement | null;

    // Áp dụng pricebook mặc định (base_price nếu không có giá trị)
    const pb = (pbSel?.value || 'base_price') as 'base_price' | 'utdao' | 'whole';
    applyPricebook(pb);

    // Event listeners
    catSel?.addEventListener('change', () => {
      applyCategoryFilter(catSel.value);
    });

    pbSel?.addEventListener('change', () => {
      const k = pbSel.value as 'base_price' | 'utdao' | 'whole';
      applyPricebook(k);
    });

    // Áp dụng filter danh mục ban đầu
    applyCategoryFilter(catSel?.value ?? '');
  }

  // === BOOTSTRAP ===
  // Khởi tạo khi DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style is:global>
  @media print {
    .no-print {
      display: none !important;
    }
  }
</style>
