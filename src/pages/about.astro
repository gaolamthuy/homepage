---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Giới thiệu - Gạo Lâm Thúy" description="Giới thiệu về Gạo Lâm Thúy, thông tin liên hệ, doanh nghiệp và thanh toán.">
  <main class="container mx-auto px-4 py-8 max-w-7xl">
    <h1 class="text-3xl font-bold mb-6">Giới thiệu về Gạo Lâm Thúy</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <section>
        <div class="card bg-base-100 shadow h-full">
          <div class="card-body">
            <div class="flex items-center justify-between mb-3">
              <h2 class="card-title text-2xl">Thông tin liên hệ</h2>
              <button class="btn btn-sm" data-copy="0901467300 - Lâm\n23 Nguyễn Đình Chiểu, Phường Đức Nhuận, TP.HCM">Copy</button>
            </div>
            <div class="space-y-2 text-base-content/80">
              <p>
                <a href="tel:0901467300" class="hover:underline">0901 467 300</a>
                <a href="https://zalo.me/0901467300" target="_blank" rel="noopener" class="inline-block align-middle hover:opacity-80 transition-opacity ml-1">
                  <img src="/icons/icons8-zalo.svg" alt="Zalo" class="w-8 h-8" />
                </a>
              </p>
              <p class="flex items-center gap-1 justify-center sm:justify-start">
                <a href="https://maps.app.goo.gl/oVAN7ZoPcL2BGQxt7" target="_blank" rel="noopener" class="link link-hover">23 Nguyễn Đình Chiểu, Phường Đức Nhuận, TP.HCM</a>
                <span class="tooltip tooltip-bottom" data-tip="Phường 4, Quận Phú Nhuận (cũ)">
                  <svg class="w-4 h-4 text-base-content/40 cursor-help" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </span>
              </p>
              <p>
                <a href="https://facebook.com/gaolamthuy" target="_blank" rel="noopener" class="btn btn-ghost btn-sm" aria-label="Facebook">
                  <img src="/icons/icons8-facebook.svg" alt="Facebook" class="w-5 h-5" loading="lazy" />
                  Facebook Fanpage
                </a>
                <a href="https://zalo.me/567000711935281744" target="_blank" rel="noopener" class="btn btn-ghost btn-sm" aria-label="Zalo">
                  <img src="/icons/icons8-zalo.svg" alt="Zalo" class="w-5 h-5" loading="lazy" />
                  Zalo Official Account
                </a>
              </p>
            </div>
          </div>
        </div>
      </section>

      <section>
        <div class="card bg-base-100 shadow h-full">
          <div class="card-body">
            <div class="flex items-center justify-between mb-3">
              <h2 class="card-title text-2xl">Thông tin thanh toán</h2>
              <button class="btn btn-sm" data-copy="Techcombank\nMS00T01926530397960\nHO KINH DOANH PHAM LAM">Copy</button>
            </div>
            <div class="flex flex-col sm:flex-row items-center gap-4">
              <div class="flex-shrink-0">
                <button type="button" id="qr-trigger" class="block rounded-lg shadow-sm bg-white p-1 cursor-zoom-in transition-transform hover:scale-105" aria-label="Phóng to mã QR">
                  <img
                    src="/970407-MS00t01926530397960-compact2.png"
                    alt="VietQR - Quét để chuyển khoản"
                    class="w-52 h-52 object-contain"
                    loading="lazy"
                  />
                </button>
                <p class="text-center text-xs text-base-content/40 mt-1">Chạm để phóng to</p>
              </div>
              <div class="space-y-1 text-base-content/80 text-center sm:text-left">
                <p><strong>Ngân hàng:</strong> Techcombank</p>
                <p class="flex items-center gap-1.5 justify-center sm:justify-start">
                  <span><strong>Số tài khoản:</strong> MS00T01926530397960</span>
                  <button class="btn btn-ghost btn-xs btn-square" data-copy="MS00T01926530397960" data-copy-icon aria-label="Copy số tài khoản">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                  </button>
                </p>
                <p><strong>Chủ tài khoản:</strong> HO KINH DOANH PHAM LAM</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- QR Zoom Modal -->
    <dialog id="qr-modal" class="modal">
      <div class="modal-box max-w-fit p-4 bg-base-100">
        <div class="flex flex-col items-center gap-3">
          <img
            src="/970407-MS00t01926530397960-compact2.png"
            alt="VietQR phóng to"
            class="w-72 h-72 sm:w-80 sm:h-80 object-contain bg-white p-2 rounded-lg"
          />
          <div class="flex gap-2">
            <button type="button" id="qr-copy-img" class="btn btn-primary btn-sm gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              <span id="qr-copy-label">Sao chép ảnh</span>
            </button>
            <a href="/970407-MS00t01926530397960-compact2.png" download="vietqr-gaolamthuy.png" class="btn btn-ghost btn-sm gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Tải xuống
            </a>
          </div>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop"><button>close</button></form>
    </dialog>
  </main>
</Layout>

<script>
  const checkSvg = '<svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('button[data-copy]')?.forEach((btnEl) => {
      const btn = btnEl as HTMLButtonElement;
      btn.addEventListener('click', async () => {
        try {
          const value = btn.getAttribute('data-copy') || '';
          await navigator.clipboard.writeText(value);
          const isIcon = btn.hasAttribute('data-copy-icon');
          const old = isIcon ? btn.innerHTML : (btn.textContent || 'Copy');
          if (isIcon) {
            btn.innerHTML = checkSvg;
          } else {
            btn.textContent = 'Đã copy';
          }
          setTimeout(() => { isIcon ? (btn.innerHTML = old) : (btn.textContent = old); }, 1200);
        } catch (e) {
          // no-op
        }
      });
    });

    // QR zoom modal
    const qrTrigger = document.getElementById('qr-trigger');
    const qrModal = document.getElementById('qr-modal') as HTMLDialogElement | null;
    qrTrigger?.addEventListener('click', () => qrModal?.showModal());

    // Copy QR image to clipboard
    const copyImgBtn = document.getElementById('qr-copy-img');
    const copyLabel = document.getElementById('qr-copy-label');
    copyImgBtn?.addEventListener('click', async () => {
      const url = '/970407-MS00t01926530397960-compact2.png';
      const original = copyLabel?.textContent || 'Sao chép ảnh';
      try {
        const res = await fetch(url);
        const blob = await res.blob();
        if (navigator.clipboard && (window as any).ClipboardItem) {
          await (navigator.clipboard as any).write([new ClipboardItem({ [blob.type]: blob })]);
        } else {
          throw new Error('Clipboard API không hỗ trợ ảnh');
        }
        if (copyLabel) copyLabel.textContent = 'Đã chép ✓';
      } catch (e) {
        // Fallback: tải ảnh xuống
        const a = document.createElement('a');
        a.href = url;
        a.download = 'vietqr-gaolamthuy.png';
        a.click();
        if (copyLabel) copyLabel.textContent = 'Đã tải xuống';
      }
      setTimeout(() => { if (copyLabel) copyLabel.textContent = original; }, 1500);
    });
  });
</script>


