---
/**
 * Trang bảng giá hình ảnh - dễ chia sẻ trên mạng xã hội
 * Sử dụng DaisyUI carousel với next/prev buttons
 * Data từ: https://cdn.gaolamthuy.vn/homepage/album_website.json
 */

import Layout from '../layouts/Layout.astro';
import { getAlbum } from '../lib/api';
import type { AlbumItem as ApiAlbumItem } from '../lib/api';

let albumItems: ApiAlbumItem[] = [];
let error: string | null = null;

try {
  albumItems = await getAlbum();
} catch (err) {
  error = err instanceof Error ? err.message : 'Lỗi không xác định khi tải album';
}

/**
 * Format datetime từ rev timestamp (milliseconds)
 */
function formatDateTime(rev: number | null): string {
  if (!rev) return 'N/A';
  
  try {
    const timestamp = rev;
    
    const date = new Date(timestamp);
    return new Intl.DateTimeFormat('vi-VN', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
    }).format(date);
  } catch {
    return 'N/A';
  }
}

/**
 * Map type sang tên hiển thị tiếng Việt
 */
function getTypeLabel(type: string): string {
  const typeMap: Record<string, string> = {
    'pricetable-retail': 'Bảng giá lẻ',
    'pricetable-whole': 'Bảng giá 200kg',
    'pricetable-utdao': 'Bảng giá 500kg',
    'misc': 'Khác',
  };
  return typeMap[type] || type;
}
---

<Layout
  title="Bảng giá hình ảnh - Gạo Lâm Thúy"
  description="Xem bảng giá dạng hình ảnh các sản phẩm gạo chất lượng cao từ Gạo Lâm Thúy - dễ chia sẻ trên mạng xã hội"
>
  <main class="container mx-auto px-4 py-8">
    <div class="alert alert-warning mb-6 max-w-2xl mx-auto">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
      </svg>
      <div>
        <h3 class="font-bold">Trang này đã lỗi thời</h3>
        <div class="text-sm">Vui lòng dùng <a href="/album" class="link link-primary font-semibold">Album ảnh</a> mới — tối ưu vuốt, zoom cho điện thoại.</div>
      </div>
      <a href="/album" class="btn btn-sm btn-warning">Đi tới Album ảnh</a>
    </div>
    <h1 class="text-4xl font-bold mb-8 text-center">Bảng Giá Hình Ảnh</h1>
    <p class="text-center text-base-content/70 mb-8 max-w-2xl mx-auto">
      Xem và tải xuống bảng giá dạng hình ảnh để dễ dàng chia sẻ trên mạng xã hội hoặc gửi cho khách hàng
    </p>

    {error ? (
      <div class="alert alert-error mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>{error}</span>
      </div>
    ) : albumItems.length === 0 ? (
      <div class="alert alert-info mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>Chưa có ảnh nào trong album</span>
      </div>
    ) : (
      <div class="carousel w-full rounded-box">
        {albumItems.map((item, index) => {
          const imageUrl = item.public_url || '';
          const displayTitle = item.title_public || item.title;
          const itemId = `slide${index + 1}`;
          
          return (
            <div id={itemId} class="carousel-item relative w-full">
              <div class="card bg-base-100 shadow-xl w-full max-w-4xl mx-auto">
                <figure class="px-4 pt-4">
                  {imageUrl ? (
                    <img
                      src={imageUrl}
                      alt={displayTitle}
                      class="rounded-xl w-full object-contain"
                      style="aspect-ratio: 3/4; max-height: 80vh;"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full bg-base-200 flex items-center justify-center" style="aspect-ratio: 3/4; max-height: 80vh;">
                      <span class="text-base-content/50">Không có ảnh</span>
                    </div>
                  )}
                </figure>
                <div class="card-body items-center text-center">
                  <h2 class="card-title text-2xl">{displayTitle}</h2>
                  <p class="text-base-content/70">
                    <span class="font-semibold">Loại:</span> {getTypeLabel(item.type)}
                  </p>
                  <p class="text-base-content/70">
                    <span class="font-semibold">Cập nhật:</span> {formatDateTime(item.rev)}
                  </p>
                </div>
              </div>
              <div class="absolute left-5 right-5 top-1/2 flex -translate-y-1/2 justify-between">
                <a href={index === 0 ? `#slide${albumItems.length}` : `#slide${index}`} class="btn btn-circle">
                  ❮
                </a>
                <a href={index === albumItems.length - 1 ? `#slide1` : `#slide${index + 2}`} class="btn btn-circle">
                  ❯
                </a>
              </div>
            </div>
          );
        })}
      </div>
      <div class="flex justify-center w-full py-2 gap-2 flex-wrap">
        {albumItems.map((item, index) => {
          const itemId = `slide${index + 1}`;
          const displayTitle = item.title_public || item.title;
          return (
            <a href={`#${itemId}`} class="btn btn-xs" title={displayTitle}>
              {displayTitle}
            </a>
          );
        })}
      </div>
    )}
  </main>
</Layout>
