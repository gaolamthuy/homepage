---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getProducts, getCategories } from '../../lib/api';
import type { ProductResponse } from '../../types/product';

const data = (await getProducts()) as ProductResponse;
const products = data.products_data || [];
const categoriesRes = await getCategories();
const categories = (categoriesRes.categories_data || [])
  .slice()
  .sort((a, b) => (a.rank ?? 9999) - (b.rank ?? 9999));

const byCategoryCount = products.reduce((acc, p) => {
  acc[p.category_name] = (acc[p.category_name] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const categoriesWithCounts = categories.map((c) => ({
  ...c,
  homepage_item_count: (c as any).homepage_item_count ?? byCategoryCount[c.category_name] ?? 0,
}));
---

<Layout
  title="Tất cả sản phẩm - Gạo Lâm Thúy"
  description="Danh sách tất cả sản phẩm, lọc theo nhu cầu."
>
  <main class="container mx-auto px-4 py-8 max-w-7xl">
    <h1 class="text-3xl font-bold mb-6">Tất cả sản phẩm</h1>

    <div class="mb-8 flex md:flex-wrap gap-1 items-center overflow-x-auto md:overflow-visible pb-2 md:pb-0 scrollbar-none whitespace-nowrap md:whitespace-normal" id="v2-filter-bar">
      <button
        type="button"
        class="btn btn-square btn-md flex-shrink-0"
        id="v2-filter-reset"
        aria-label="Xóa bộ lọc"
        title="Hiển thị tất cả sản phẩm"
      >
        ×
      </button>
      {categoriesWithCounts.map((c) => (
        <button
          type="button"
          class="btn btn-md btn-category-filter flex-shrink-0"
          data-category={c.category_name}
        >
          {c.category_name}
          <span class="badge badge-sm badge-outline">
            {c.homepage_item_count}
          </span>
        </button>
      ))}
    </div>

    <div
      id="v2-products-container"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"
    >
      {products.map((product) => (
        <div
          class="product-item"
          data-category-filter={product.category_name}
        >
          <ProductCard product={product} density="compact" />
        </div>
      ))}
    </div>
  </main>
</Layout>

<script>
  function init() {
    const container = document.getElementById('v2-products-container');
    const resetBtn = document.getElementById('v2-filter-reset');
    const filterBtns = document.querySelectorAll<HTMLButtonElement>(
      '.btn-category-filter'
    );
    if (!container || !resetBtn) return;

    const active = new Set<string>();

    function apply() {
      const items = container.querySelectorAll<HTMLElement>('.product-item');
      const showAll = active.size === 0;
      items.forEach((item) => {
        const cat = item.getAttribute('data-category-filter');
        item.style.display = showAll || (cat ? active.has(cat) : false) ? '' : 'none';
      });
    }

    function updateBtnStyles() {
      filterBtns.forEach((btn) => {
        const cat = btn.dataset.category ?? '';
        if (active.has(cat)) {
          btn.classList.add('btn-active', 'btn-primary', 'text-primary-content');
        } else {
          btn.classList.remove('btn-active', 'btn-primary', 'text-primary-content');
        }
      });
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.category ?? '';
        if (active.has(cat)) {
          active.delete(cat);
        } else {
          active.add(cat);
        }
        apply();
        updateBtnStyles();
      });
    });

    resetBtn.addEventListener('click', () => {
      active.clear();
      apply();
      updateBtnStyles();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style>
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
</style>
