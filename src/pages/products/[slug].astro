---
import Layout from '../../layouts/Layout.astro';
import { getProducts } from '../../lib/api';
import { getProductImage, formatPrice, getFilteredProductImages } from '../../lib/utils';
import type { Product, ProductResponse } from '../../types/product';

export const prerender = true;

interface Props {
  product: Product;
}

export async function getStaticPaths() {
  try {
    const data = (await getProducts()) as ProductResponse;
    const products = data.products_data || [];
    const itemsWithSlug = products.filter((p) => Boolean(p.glt_slug));
    return itemsWithSlug.map((p) => ({
      params: { slug: p.glt_slug as string },
      props: { product: p },
    }));
  } catch (error) {
    console.error('Error generating static paths:', error);
    return [];
  }
}

const { product } = Astro.props as Props;

if (!product) {
  return Astro.redirect('/products', 302);
}

const hasChild =
  product.child_product && product.child_product.length > 0;
const childProduct = hasChild ? product.child_product![0] : null;

const baseImages = getFilteredProductImages(product);
const childImages = childProduct
  ? getFilteredProductImages(childProduct as any)
  : [];

const mainImageUrl = getProductImage(product);
const childMainImageUrl = childProduct
  ? getProductImage(childProduct as any)
  : mainImageUrl;
---

<Layout
  title={`${product.full_name || product.name} - Gạo Lâm Thúy`}
  description={`Chi tiết sản phẩm ${product.full_name || product.name}`}
>
  <nav slot="breadcrumb" class="breadcrumbs text-sm px-4 pt-4" aria-label="Breadcrumb">
    <ul>
      <li><a href="/">Trang chủ</a></li>
      <li><a href="/products">Sản phẩm</a></li>
      {product.category_name && (
        <li>
          <a href={`/products?category=${encodeURIComponent(product.category_name)}`}>
            {product.category_name}
          </a>
        </li>
      )}
      <li aria-current="page">{product.name || product.full_name}</li>
    </ul>
  </nav>
  <div slot="breadcrumb" class="px-4 pt-2">
    <a
      href="/products"
      class="btn btn-ghost btn-sm"
      onclick="if (document.referrer) { history.back(); return false; }"
      aria-label="Quay lại trang trước"
    >
      ← Quay lại
    </a>
  </div>

  <main class="container mx-auto px-4 py-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div id="v2-image-container">
        <img
          src={mainImageUrl}
          alt={product.name || product.full_name}
          class="w-full rounded-xl shadow-md"
          loading="eager"
          id="v2-main-image"
        />
      </div>

      <div class="space-y-4">
        <div class="space-y-2">
          <h1 class="text-2xl font-extrabold text-base-content">
            {product.name || product.full_name}
          </h1>
          <div class="flex items-center gap-2 flex-wrap">
            <div class="badge badge-outline">{product.category_name}</div>
            {product.glt_retail_promotion && (
              <div class="badge badge-outline flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="currentColor" class="w-4 h-4">
                  <path d="M 16 3 C 8.832031 3 3 8.832031 3 16 C 3 23.167969 8.832031 29 16 29 C 23.167969 29 29 23.167969 29 16 C 29 8.832031 23.167969 3 16 3 Z M 16 5 C 22.085938 5 27 9.914063 27 16 C 27 22.085938 22.085938 27 16 27 C 9.914063 27 5 22.085938 5 16 C 5 9.914063 9.914063 5 16 5 Z M 15 10 L 15 12 L 17 12 L 17 10 Z M 15 14 L 15 22 L 17 22 L 17 14 Z"></path>
                </svg>
                Khuyến mãi
              </div>
            )}
            {hasChild && (
              <div class="badge badge-outline flex items-center gap-1">Nhiều loại</div>
            )}
          </div>
        </div>

        <div id="v2-product-info" class="space-y-4">
          <div
            class="text-md font-semibold text-base-content/70"
            id="v2-full-name"
          >
            {childProduct ? childProduct.full_name : product.full_name}
            {(childProduct?.order_template || product.order_template) && (
              <> • {childProduct?.order_template || product.order_template}</>
            )}
          </div>

          <div class="flex items-center gap-3">
            <span
              class="text-3xl font-bold text-primary"
              id="v2-price"
              data-base-price={product.base_price}
              data-child-price={childProduct?.base_price ?? ''}
            >
              {formatPrice(childProduct ? childProduct.base_price : product.base_price)}
            </span>
            <span class="text-sm text-base-content/70" id="v2-unit">
              /{childProduct ? childProduct.unit : product.unit}
            </span>
          </div>

          {(childProduct?.child_unit || product.child_unit) && (
            <div class="mt-2 p-3 bg-base-200 rounded-lg" id="v2-child-unit-block">
              <div
                class="text-sm font-semibold text-base-content/80 mb-1"
                id="v2-child-unit-name"
              >
                {(childProduct?.child_unit || product.child_unit)!.full_name}
              </div>
              <div class="flex items-center gap-2 text-sm">
                <span class="font-bold text-primary" id="v2-child-unit-price">
                  {formatPrice(
                    (childProduct?.child_unit || product.child_unit)!.base_price
                  )}
                </span>
                <span class="text-base-content/70" id="v2-child-unit-unit">
                  /{(childProduct?.child_unit || product.child_unit)!.unit}
                </span>
                {(childProduct?.child_unit || product.child_unit)!
                  .price_per_master_unit != null && (
                  <span class="text-xs text-base-content/60" id="v2-child-unit-conversion">
                    (Quy đổi:{' '}
                    {formatPrice(
                      (childProduct?.child_unit || product.child_unit)!
                        .price_per_master_unit!
                    )}
                    /kg)
                  </span>
                )}
              </div>
            </div>
          )}

          {baseImages.length > 0 && (
            <div class="mt-4 p-4 rounded-xl bg-base-100 shadow">
              <h3 class="text-sm font-semibold mb-3 text-base-content/80">
                Hình ảnh sản phẩm
              </h3>
              <div class="flex gap-2 overflow-x-auto pb-2" id="v2-thumbnails">
                {(hasChild ? childImages : baseImages).map(
                  (img) => (
                    <div
                      class="v2-thumb relative flex-shrink-0 w-20 h-20 rounded-lg overflow-hidden cursor-pointer hover:scale-105 transition-transform duration-200"
                      data-img-url={img.url}
                      data-img-role={img.role}
                    >
                      <img
                        src={img.url}
                        alt={`${img.role}`}
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                      <div class="absolute inset-0 bg-black/0 hover:bg-black/10 transition-colors duration-200" />
                      <div class="absolute bottom-0 left-0 right-0 bg-black/60 text-white text-xs px-1 py-0.5 text-center truncate">
                        {img.role.replace('-', ' ')}
                      </div>
                    </div>
                  )
                )}
              </div>
            </div>
          )}

          {hasChild && (
            <div class="mt-2 p-4 rounded-xl bg-base-100 shadow">
              <h2 class="text-base font-bold mb-3">Lựa chọn biến thể</h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <button
                  type="button"
                  class="v2-variant-btn indicator border rounded-lg p-3 text-left hover:border-primary transition-all duration-300 w-full"
                  data-variant="base"
                >
                  <div class="space-y-1">
                    <div class="text-base font-semibold line-clamp-1">
                      {product.full_name}
                    </div>
                    {product.order_template && (
                      <div class="text-xs text-base-content/60 line-clamp-1">
                        {product.order_template}
                      </div>
                    )}
                    <div class="text-xl font-extrabold text-primary">
                      {formatPrice(product.base_price)}
                    </div>
                  </div>
                </button>

                <button
                  type="button"
                  class="v2-variant-btn indicator border rounded-lg p-3 text-left hover:border-primary transition-all duration-300 w-full"
                  data-variant="child"
                >
                  <div class="space-y-1">
                    <div class="text-base font-semibold line-clamp-1">
                      {childProduct!.full_name}
                    </div>
                    {(childProduct!.order_template || product.order_template) && (
                      <div class="text-xs text-base-content/60 line-clamp-1">
                        {childProduct!.order_template || product.order_template}
                      </div>
                    )}
                    <div class="text-xl font-extrabold text-primary">
                      {formatPrice(childProduct!.base_price)}
                    </div>
                  </div>
                </button>
              </div>
              <div class="mt-3 text-xs text-base-content/60 flex items-center gap-1">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  class="w-3 h-3"
                >
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                </svg>
                Hình ảnh sẽ cập nhật theo lựa chọn
              </div>
            </div>
          )}
        </div>

        <div class="flex gap-3 pt-2">
          <a href="https://zalo.me/0901467300" class="btn btn-primary">
            Liên hệ
          </a>
          {product.glt_kiotvietshop_url && (
            <a
              href={product.glt_kiotvietshop_url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary btn-outline"
            >
              Đặt hàng online
            </a>
          )}
          {product.glt_shopee_url && (
            <a
              href={product.glt_shopee_url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn"
            >
              Xem trên Shopee
            </a>
          )}
        </div>
      </div>
    </div>
  </main>
</Layout>

<script
  define:vars={{
    hasChild,
    baseImages,
    childImages,
    baseFullName: product.full_name,
    baseOrderTemplate: product.order_template || '',
    childFullName: childProduct?.full_name || '',
    childOrderTemplate: childProduct?.order_template || product.order_template || '',
    baseUnit: product.unit,
    childUnit: childProduct?.unit || product.unit,
    basePrice: product.base_price,
    childPrice: childProduct?.base_price ?? 0,
    childUnitInfo: childProduct?.child_unit || product.child_unit || null,
    baseChildUnit: product.child_unit || null,
  }}
>
  const NF = new Intl.NumberFormat('vi-VN');
  function fmt(n) {
    return NF.format(n);
  }

  const mainImage = document.getElementById('v2-main-image');
  const priceEl = document.getElementById('v2-price');
  const unitEl = document.getElementById('v2-unit');
  const fullNameEl = document.getElementById('v2-full-name');
  const thumbContainer = document.getElementById('v2-thumbnails');
  const variantBtns = document.querySelectorAll('.v2-variant-btn');
  const childUnitBlock = document.getElementById('v2-child-unit-block');
  const childUnitName = document.getElementById('v2-child-unit-name');
  const childUnitPrice = document.getElementById('v2-child-unit-price');
  const childUnitUnit = document.getElementById('v2-child-unit-unit');
  const childUnitConversion = document.getElementById('v2-child-unit-conversion');

  let currentVariant = hasChild ? 'child' : 'base';

  function getImagesForVariant(v) {
    if (v === 'child' && hasChild) {
      return childImages.length > 0 ? childImages : baseImages;
    }
    return baseImages;
  }

  function getMainImageForVariant(v) {
    const imgs = getImagesForVariant(v);
    if (imgs.length === 0) return null;
    const main =
      imgs.find((i) => i.role === 'feature-main') ||
      imgs.find((i) => i.role === 'closeup-main') ||
      imgs[0];
    return main.url;
  }

  function preloadAndSetSrc(url, alt) {
    if (!mainImage) return;
    const img = new Image();
    img.onload = () => {
      mainImage.src = url;
      mainImage.alt = alt;
    };
    img.src = url;
  }

  function updateUI(v) {
    currentVariant = v;
    const isChild = v === 'child' && hasChild;
    const price = isChild ? childPrice : basePrice;
    const unit = isChild ? childUnit : baseUnit;
    const fullName = isChild ? childFullName : baseFullName;
    const orderTemplate = isChild ? childOrderTemplate : baseOrderTemplate;

    if (priceEl) priceEl.textContent = fmt(price);
    if (unitEl) unitEl.textContent = '/' + unit;
    if (fullNameEl) {
      fullNameEl.innerHTML =
        fullName + (orderTemplate ? ' &bull; ' + orderTemplate : '');
    }

    const unitInfo = isChild
      ? childUnitInfo || baseChildUnit
      : baseChildUnit;
    if (childUnitBlock) {
      if (unitInfo) {
        childUnitBlock.style.display = '';
        if (childUnitName) childUnitName.textContent = unitInfo.full_name;
        if (childUnitPrice) childUnitPrice.textContent = fmt(unitInfo.base_price);
        if (childUnitUnit) childUnitUnit.textContent = '/' + unitInfo.unit;
        if (childUnitConversion) {
          if (unitInfo.price_per_master_unit != null) {
            childUnitConversion.textContent =
              '(Quy đổi: ' + fmt(unitInfo.price_per_master_unit) + '/kg)';
          } else {
            childUnitConversion.textContent = '';
          }
        }
      } else {
        childUnitBlock.style.display = 'none';
      }
    }

    const imgUrl = getMainImageForVariant(v);
    if (imgUrl) {
      preloadAndSetSrc(imgUrl, fullName);
    }

    renderThumbnails(v);
    updateVariantStyles(v);
  }

  function renderThumbnails(v) {
    if (!thumbContainer) return;
    const imgs = getImagesForVariant(v);
    thumbContainer.innerHTML = '';
    imgs.forEach((img) => {
      const div = document.createElement('div');
      div.className =
        'v2-thumb relative flex-shrink-0 w-20 h-20 rounded-lg overflow-hidden cursor-pointer hover:scale-105 transition-transform duration-200';
      div.dataset.imgUrl = img.url;
      div.dataset.imgRole = img.role;
      div.innerHTML =
        '<img src="' +
        img.url +
        '" alt="' +
        img.role +
        '" class="w-full h-full object-cover" loading="lazy" />' +
        '<div class="absolute inset-0 bg-black/0 hover:bg-black/10 transition-colors duration-200"></div>' +
        '<div class="absolute bottom-0 left-0 right-0 bg-black/60 text-white text-xs px-1 py-0.5 text-center truncate">' +
        img.role.replace('-', ' ') +
        '</div>';
      div.addEventListener('click', () => {
        if (mainImage) {
          mainImage.src = img.url;
          mainImage.alt = img.role;
          highlightThumb(div);
        }
      });
      thumbContainer.appendChild(div);
    });
  }

  function highlightThumb(activeDiv) {
    if (!thumbContainer) return;
    thumbContainer.querySelectorAll('.v2-thumb').forEach((t) => {
      t.classList.remove('ring-2', 'ring-primary');
      const check = t.querySelector('.thumb-check');
      if (check) check.remove();
    });
    activeDiv.classList.add('ring-2', 'ring-primary');
  }

  function updateVariantStyles(v) {
    variantBtns.forEach((btn) => {
      const bv = btn.dataset.variant;
      const isSelected = bv === v;
      if (isSelected) {
        btn.classList.add('border-primary', 'bg-primary/5');
        btn.classList.remove('hover:bg-base-200');
        let badge = btn.querySelector('.v2-variant-badge');
        if (!badge) {
          badge = document.createElement('span');
          badge.className =
            'v2-variant-badge indicator-item indicator-top indicator-end badge badge-primary badge-sm -translate-y-2 translate-x-2';
          badge.textContent = 'Đang chọn';
          btn.appendChild(badge);
        }
      } else {
        btn.classList.remove('border-primary', 'bg-primary/5');
        btn.classList.add('hover:bg-base-200');
        const badge = btn.querySelector('.v2-variant-badge');
        if (badge) badge.remove();
      }
    });
  }

  variantBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const v = btn.dataset.variant;
      if (v) updateUI(v);
    });
  });

  if (hasChild) {
    updateUI('child');
  } else {
    updateUI('base');
  }
</script>
