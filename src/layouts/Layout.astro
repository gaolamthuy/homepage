---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PhotoSwipeGallery from '../components/PhotoSwipeGallery.astro';
import type { LayoutProps } from '../types/product';
import '../assets/app.css';

export interface Props extends LayoutProps {
  totalProducts?: number;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const {
  title = "Gạo Lâm Thúy",
  description = "Gạo, Tấm, Nếp cho mọi nhà",
  totalProducts = 0,
  ogImage,
  ogType = "website",
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL("/og-default.png", Astro.site).href;

const localBusinessJsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": Astro.site!.href,
  name: "Gạo Lâm Thúy",
  url: Astro.site!.href,
  logo: new URL("/favicon_io/apple-touch-icon.png", Astro.site).href,
  telephone: "0901467300",
  address: {
    "@type": "PostalAddress",
    streetAddress: "23 Nguyễn Đình Chiểu, Phường Đức Nhuận",
    addressLocality: "TP. Hồ Chí Minh",
    addressCountry: "VN",
  },
  sameAs: [
    "https://facebook.com/gaolamthuy",
    "https://zalo.me/0901467300",
  ],
  priceRange: "$$",
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Gạo Lâm Thúy",
  url: Astro.site!.href,
};
---

<!DOCTYPE html>
<html lang="vi" data-theme="bumblebee">
  <head>
    <meta charset="utf-8" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon_io/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon_io/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon_io/favicon-16x16.png" />
    <link rel="icon" type="image/x-icon" href="/favicon_io/favicon.ico" />
    <link rel="manifest" href="/favicon_io/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="Gạo Lâm Thúy" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(localBusinessJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
  </head>
  <body>
    <Header totalProducts={totalProducts} />
    <div class="mx-auto max-w-7xl">
      <slot name="breadcrumb" />
      <slot />
    </div>
    <Footer />
    
    <!-- Floating Action Button (FAB) - Global -->
    <div class="fab">
      <!-- Main FAB button -->
      <div tabindex="0" role="button" class="btn btn-lg btn-circle btn-ghost">
        <a href="https://zalo.me/0901467300" target="_blank" rel="noopener noreferrer" class="btn btn-lg btn-circle">
          <img src="/icons/icons8-zalo.svg" alt="Zalo" class="w-8 h-8" />
        </a>
      </div>

      <!-- Main Action button replaces the original button when FAB is open -->
      <div class="fab-main-action">
        <!-- <span class="tooltip tooltip-left">Zalo</span> -->
        <button class="btn btn-lg btn-circle btn-ghost">
          <a href="https://zalo.me/0901467300" target="_blank" rel="noopener noreferrer" class="btn btn-lg btn-circle">
            <img src="/icons/icons8-zalo.svg" alt="Zalo" class="w-8 h-8" />
          </a>
        </button>
      </div>

      <!-- Speed dial buttons -->

      <div class="tooltip tooltip-left" data-tip="Gọi điện">
        <a href="tel:0901467300" class="btn btn-lg btn-circle btn-ghost">
          <img src="/icons/icons8-call.svg" alt="Call" class="w-8 h-8" />
        </a>
      </div>

    </div>
    
    <!-- PhotoSwipe Gallery Component - Global -->
    <PhotoSwipeGallery />
    
    <!-- Theme-change library -->
    <script is:inline>
      // Prevent FART effect - apply theme before rendering
      // Default theme: bumblebee (light), forest (dark)
      function getInitialTheme() {
        // Kiểm tra localStorage trước
        const savedTheme = localStorage.getItem("theme");
        if (savedTheme) {
          return savedTheme;
        }
        
        // Detect device theme preference
        if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return "forest"; // Dark mode
        }
        
        return "bumblebee"; // Light mode default
      }
      
      // Áp dụng theme ngay lập tức
      document.documentElement.setAttribute("data-theme", getInitialTheme());
    </script>
    <script>
      import { themeChange } from 'theme-change';
      
      // Khởi tạo theme-change library
      themeChange();
      
      // Debug: Log current theme
      console.log('Current theme:', document.documentElement.getAttribute('data-theme'));
      
      // Listen for device theme changes
      if (window.matchMedia) {
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
          // Chỉ áp dụng nếu user chưa có theme preference được lưu
          if (!localStorage.getItem("theme")) {
            const newTheme = e.matches ? "forest" : "bumblebee";
            document.documentElement.setAttribute("data-theme", newTheme);
            console.log('Device theme changed to:', newTheme);
          }
        });
      }
    </script>
  </body>
</html>
